{
  "ams": {
    "grid": {
      "padding-inline": {
        "$value": "{ams.space.xl}",
        "$extensions": {
          "nl.amsterdam.subtype": "space",
          "nl.amsterdam.type": "dimension"
        }
      },
      "cell": {
        "background-color": {
          "$value": "{ams.color.background.default}",
          "$type": "color"
        },
        "padding-block": {
          "$value": "{ams.space.m}",
          "$extensions": {
            "nl.amsterdam.subtype": "space",
            "nl.amsterdam.type": "dimension"
          }
        },
        "padding-inline": {
          "$value": "{ams.space.m}",
          "$extensions": {
            "nl.amsterdam.subtype": "space",
            "nl.amsterdam.type": "dimension"
          }
        }
      }
    }
  }
}
