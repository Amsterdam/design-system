{
  "ams": {
    "accordion": {
      "gap": {
        "$value": "{ams.space.s}",
        "$type": "dimension",
        "$extensions": {
          "nl.amsterdam.subtype": "space"
        }
      },
      "button": {
        "font-family": {
          "$deprecated": "The Accordion section button now uses a Heading component. Use the Heading component tokens instead.",
          "$value": "{ams.typography.font-family}",
          "$type": "fontFamily"
        },
        "font-size": {
          "$deprecated": "The Accordion section button now uses a Heading component. Use the Heading component tokens instead.",
          "$value": "{ams.typography.heading.3.font-size}",
          "$extensions": {
            "nl.amsterdam.type": "fontSize"
          }
        },
        "font-weight": {
          "$deprecated": "The Accordion section button now uses a Heading component. Use the Heading component tokens instead.",
          "$value": "{ams.typography.heading.font-weight}",
          "$type": "fontWeight"
        },
        "line-height": {
          "$deprecated": "The Accordion section button now uses a Heading component. Use the Heading component tokens instead.",
          "$value": "{ams.typography.heading.3.line-height}",
          "$extensions": {
            "nl.amsterdam.type": "lineHeight"
          }
        },
        "text-wrap": {
          "$deprecated": "The Accordion section button now uses a Heading component. Use the Heading component tokens instead.",
          "$value": "{ams.typography.heading.text-wrap}"
        },
        "color": {
          "$value": "{ams.color.interactive.default}",
          "$type": "color"
        },
        "cursor": {
          "$value": "{ams.cursor.interactive}"
        },
        "gap": {
          "$value": "{ams.space.s}",
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.subtype": "space"
          }
        },
        "outline-offset": {
          "$value": "{ams.focus.outline-offset}",
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.subtype": "space"
          }
        },
        "padding-block": {
          "$value": "{ams.space.s}",
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.subtype": "space"
          }
        },
        "padding-inline": {
          "$value": "0",
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.subtype": "space"
          }
        },
        "hover": {
          "color": {
            "$value": "{ams.color.interactive.hover}",
            "$type": "color"
          }
        }
      },
      "panel": {
        "padding-block": {
          "$deprecated": "This token will be removed in a future release.",
          "$value": "0"
        },
        "padding-inline": {
          "$deprecated": "This token will be removed in a future release.",
          "$value": "0"
        }
      }
    }
  }
}
