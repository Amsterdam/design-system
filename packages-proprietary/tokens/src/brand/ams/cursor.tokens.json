{
  "ams": {
    "cursor": {
      "disabled": {
        "$value": "not-allowed",
        "$extensions": {
          "nl.amsterdam.type": "cursor"
        }
      },
      "interactive": {
        "$value": "pointer",
        "$description": "All interactive elements in their default state that lack a cursor style.",
        "$extensions": {
          "nl.amsterdam.type": "cursor"
        }
      }
    }
  }
}
