{
  "ams": {
    "typography": {
      "font-family": {
        "$value": "'Amsterdam Sans', Arial, sans-serif",
        "$type": "fontFamily"
      },
      "hyphenate-limit-chars": {
        "$value": "auto"
      },
      "body-text": {
        "font-size": {
          "$value": "clamp(1.125rem, 1.0893rem + 0.1786vw, 1.25rem)",
          "$extensions": {
            "nl.amsterdam.type": "fontSize"
          }
        },
        "font-weight": {
          "$value": "400",
          "$type": "fontWeight"
        },
        "line-height": {
          "$value": "1.6",
          "$extensions": {
            "nl.amsterdam.type": "lineHeight"
          }
        },
        "bold": {
          "font-weight": {
            "$value": "800",
            "$type": "fontWeight"
          }
        },
        "small": {
          "font-size": {
            "$value": {
              "value": 1,
              "unit": "rem"
            },
            "$type": "dimension"
          },
          "line-height": {
            "$value": "1.5",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "large": {
          "font-size": {
            "$value": "clamp(1.3125rem, 1.2411rem + 0.3571vw, 1.5625rem)",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.5",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "x-large": {
          "font-size": {
            "$value": "clamp(1.5rem, 1.3571rem + 0.7143vw, 2rem)",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.4",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        }
      },
      "heading": {
        "font-weight": {
          "$value": "800",
          "$type": "fontWeight"
        },
        "text-wrap": {
          "$value": "balance"
        },
        "0": {
          "font-size": {
            "$deprecated": "Use `ams.typography.heading.1.font-size` instead. Will be removed in release 4.0.0.",
            "$value": "clamp(2.435rem, 2.0409rem + 1.9709vw, 3.8147rem)",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$deprecated": "Use `ams.typography.heading.1.line-height` instead. Will be removed in release 4.0.0.",
            "$value": "1.1",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "1": {
          "font-size": {
            "$value": "clamp(2rem, 1.7143rem + 1.4286vw, 3rem)",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.2",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "2": {
          "font-size": {
            "$value": "{ams.typography.body-text.x-large.font-size}",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.3",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "3": {
          "font-size": {
            "$value": "{ams.typography.body-text.large.font-size}",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.3",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "4": {
          "font-size": {
            "$value": "{ams.typography.body-text.font-size}",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.4",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "5": {
          "font-size": {
            "$value": "{ams.typography.body-text.small.font-size}",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$value": "1.4",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        },
        "6": {
          "font-size": {
            "$deprecated": "Use `ams.typography.heading.5.font-size` instead. Will be removed in release 4.0.0.",
            "$value": "{ams.typography.body-text.small.font-size}",
            "$extensions": {
              "nl.amsterdam.type": "fontSize"
            }
          },
          "line-height": {
            "$deprecated": "Use `ams.typography.heading.5.line-height` instead. Will be removed in release 4.0.0.",
            "$value": "1.4",
            "$extensions": {
              "nl.amsterdam.type": "lineHeight"
            }
          }
        }
      }
    }
  }
}
