{
  "ams": {
    "links": {
      "color": {
        "$value": "{ams.color.interactive.default}",
        "$type": "color"
      },
      "text-decoration-thickness": {
        "$value": {
          "value": 0.125,
          "unit": "rem"
        },
        "$type": "dimension",
        "$extensions": {
          "nl.amsterdam.hint": "2px"
        }
      },
      "text-underline-offset": {
        "$value": {
          "value": 0.15625,
          "unit": "rem"
        },
        "$type": "dimension",
        "$extensions": {
          "nl.amsterdam.hint": "2.5px",
          "nl.amsterdam.subtype": "space"
        }
      },
      "hover": {
        "color": {
          "$value": "{ams.color.interactive.hover}",
          "$type": "color"
        },
        "text-decoration-thickness": {
          "$value": {
            "value": 0.1875,
            "unit": "rem"
          },
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.hint": "3px"
          }
        },
        "text-underline-offset": {
          "$value": {
            "value": 0.09375,
            "unit": "rem"
          },
          "$type": "dimension",
          "$extensions": {
            "nl.amsterdam.hint": "1.5px",
            "nl.amsterdam.subtype": "space"
          }
        }
      },
      "subtle": {
        "text-decoration-line": {
          "$value": "none",
          "$extensions": {
            "nl.amsterdam.type": "textDecorationLine"
          }
        },
        "hover": {
          "text-decoration-line": {
            "$value": "underline",
            "$extensions": {
              "nl.amsterdam.type": "textDecorationLine"
            }
          }
        }
      },
      "contrast": {
        "color": {
          "$value": "{ams.color.interactive.contrast}"
        },
        "hover": {
          "color": {
            "$value": "{ams.color.interactive.contrast}"
          }
        },
        "$type": "color"
      },
      "inverse": {
        "color": {
          "$value": "{ams.color.interactive.inverse}"
        },
        "hover": {
          "color": {
            "$value": "{ams.color.interactive.inverse}"
          }
        },
        "$type": "color"
      }
    }
  }
}
