{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "#storybook/*": ["./src/*"],
      "#tokens/*": ["../packages-proprietary/tokens/src/*"]
    },
    "skipLibCheck": true
  },
  "extends": "../tsconfig.json",
  "include": [
    "../packages/react/src/**/*.ts",
    "../packages/react/src/**/*.tsx",
    "../packages-proprietary/react-icons/src/**/*.ts",
    "../packages-proprietary/react-icons/src/**/*.tsx",
    "config/**/*.ts",
    "config/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules/*",
    "../packages/**/*.test.ts",
    "../packages/**/*.test.tsx",
    "../packages-proprietary/**/*.test.ts",
    "../packages-proprietary/**/*.test.tsx"
  ]
}
