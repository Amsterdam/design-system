{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "../packages/react/src/**/*.ts",
    "../packages/react/src/**/*.tsx",
    "../packages-proprietary/react-icons/src/**/*.ts",
    "../packages-proprietary/react-icons/src/**/*.tsx"
  ]
}
